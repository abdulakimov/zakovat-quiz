{
  "name": "quiz-creator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "next dev",
    "dev:app": "next dev -p 3000",
    "tunnel": "powershell -NoProfile -Command \"$p=$env:TUNNEL_PORT; if (-not $p) { $p='3201' }; ssh -o ExitOnForwardFailure=yes -N -R 127.0.0.1:$p`:localhost:3000 zakovat-vps\"",
    "dev:remote": "concurrently -k -n APP,TUNNEL \"pnpm dev:app\" \"pnpm tunnel\"",
    "build": "next build",
    "start": "next start",
    "start:prod": "pnpm start -p 3100",
    "test": "pnpm run test:compile && node .tmp-tests-run/scripts/presenter-reducer-test.js && node .tmp-tests-run/scripts/url-origin-test.js && node .tmp-tests-run/scripts/auth-schema-test.js && node .tmp-tests-run/scripts/question-schema-test.js && node .tmp-tests-run/scripts/provider-avatar-test.js && node .tmp-tests-run/scripts/rhf-zod-resolver-test.js",
    "check:prod": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "diag:font": "node scripts/font-diagnose.mjs",
    "verify:prod": "node scripts/verify-prod.mjs",
    "e2e:server": "node scripts/e2e-server.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:compile": "tsc --pretty false -p tsconfig.test.json --outDir .tmp-tests-run --incremental false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit --incremental false",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx scripts/seed.ts"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "jose": "^5.9.2",
    "lucide-react": "^0.487.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.53.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.1",
    "typescript": "^5"
  }
}
