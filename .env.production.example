DATABASE_URL=postgresql://quiz:quiz@localhost:5432/quiz_creator?schema=public
SESSION_SECRET=replace-with-strong-random-string
APP_BASE_URL=https://your-domain.com
PUBLIC_APP_URL=https://your-domain.com
LOCAL_HTTPS=false
DEBUG_AUTH=false
NEXT_PUBLIC_APP_URL=https://your-domain.com
TELEGRAM_OIDC_CLIENT_ID=123456789
TELEGRAM_OIDC_CLIENT_SECRET=replace-with-telegram-client-secret
TELEGRAM_OIDC_REDIRECT_URI=https://your-domain.com/auth/telegram/callback
TELEGRAM_OIDC_ALLOWED_ORIGIN=https://your-domain.com
GOOGLE_OIDC_CLIENT_ID=replace-with-google-client-id
GOOGLE_OIDC_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OIDC_REDIRECT_URI=https://your-domain.com/auth/google/callback
GOOGLE_OIDC_SCOPES=openid email profile
UPLOAD_ROOT=./data/uploads
# Security note: rotate any previously exposed bot token/client secret before production use.
