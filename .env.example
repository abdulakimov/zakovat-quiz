POSTGRES_USER=quiz
POSTGRES_PASSWORD=quiz
POSTGRES_DB=quiz_creator
DATABASE_URL=postgresql://quiz:quiz@localhost:5432/quiz_creator?schema=public
SESSION_SECRET=replace-with-strong-random-string
NEXT_PUBLIC_APP_URL=https://your-domain.com
TELEGRAM_OIDC_CLIENT_ID=123456789
TELEGRAM_OIDC_CLIENT_SECRET=replace-with-telegram-client-secret
TELEGRAM_OIDC_REDIRECT_URI=https://your-domain.com/auth/telegram/callback
TELEGRAM_OIDC_ALLOWED_ORIGIN=https://your-domain.com
UPLOAD_ROOT=./data/uploads
# Security note: if any bot token/client secret was exposed in chat/history, treat it as compromised and rotate it immediately.
